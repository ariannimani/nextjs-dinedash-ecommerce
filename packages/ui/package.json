{
  "name": "@dinedash/ui",
  "version": "0.0.0",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "license": "UNLICENSED",
  "repository": "https://github.com/ariannimani/nextjs-dinedash-ecommerce",
  "scripts": {
    "test": "jest",
    "test:ci": "CI=true yarn test --testLocationInResults --json --output-file=jest-output.json --silent --bail",
    "dev": "tsup src/index.ts --format cjs --watch --dts --external react --external react-dom --external styled-components",
    "dev:sb": "start-storybook -p 6006",
    "build-storybook": "storybook build",
    "build": "tsup src/index.ts --format cjs --dts --external react --external react-dom --external styled-components --minify --treeshake",
    "tsc": "tsc --noEmit",
    "storybook": "storybook dev -p 6006"
  },
  "devDependencies": {
    "@dinedash/eslint-config": "*",
    "@dinedash/theme": "*",
    "@dinedash/typescript-config": "*",
    "@storybook/react": "^7.6.7",
    "@storybook/react-vite": "^7.6.7",
    "@swc/core": "^1.3.102",
    "@testing-library/jest-dom": "^5.16.3",
    "@testing-library/react": "^12.1.5",
    "@turbo/gen": "^1.10.12",
    "@types/node": "^20.5.2",
    "@types/react": "^18.2.0",
    "@types/styled-components": "5.1.7",
    "@typescript-eslint/parser": "^6.11.0",
    "csstype": "^3.1.3",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-turbo": "^1.10.12",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-storybook": "^0.6.15",
    "hoist-non-react-statics": "^3.3.2",
    "jest": "^27.5.1",
    "jest-styled-components": "^6.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "snapshot-diff": "^0.10.0",
    "storybook": "^7.6.7",
    "styled-components": "^6.1.6",
    "typescript": "^5.2.2"
  }
}
