{
  "name": "@dinedash/nextjs-dinedash-ecommerce",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start",
    "start:web": "turbo run start --scope=web",
    "dev": "turbo run dev --parallel",
    "gen:gql": "turbo run gen:gql",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "tsc": "turbo run tsc",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "create:icon": "hygen component icon",
    "create:component": "hygen component new",
    "cci": "pnpm create:icon",
    "cc": "pnpm create:component",
    "build:storybook": "turbo run build-storybook",
    "build:packages": "turbo run build --filter=\"!./apps/**\"",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ],
    "*": [
      "commitlint --edit $1"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@dinedash/eslint-config": "workspace:^",
    "@dinedash/prettier-config": "workspace:^",
    "@dinedash/typescript-config": "workspace:^",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.11.0",
    "cz-customizable": "^7.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest-dom": "^5.1.0",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-storybook": "^0.6.15",
    "eslint-plugin-testing-library": "^6.2.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "turbo": "^1.11.2"
  },
  "packageManager": "pnpm@8.9.0",
  "engines": {
    "npm": "unsupported; use pnpm",
    "yarn": "unsupported; use pnpm",
    "node": ">=18",
    "pnpm": ">=8.9.0"
  }
}
