{
  "extends": "@dinedash/typescript-config/web.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "strict": true,
    "noEmit": false,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/types/express.d.ts",
    "./src/*",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ]
}
